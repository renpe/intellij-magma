<idea-plugin>
    <id>com.renpe.magma</id>
    <name>Magma</name>
    <vendor email="" url="https://github.com/renpe/intellij-magma">René Peschmann</vendor>
    <change-notes><![CDATA[
        <h3>1.1.0</h3>
        <ul>
            <li>Run Magma scripts from the IDE: dedicated run configuration type,
                gutter <i>Run</i> action, and right-click <i>Run 'script.m'</i>.</li>
            <li>WSL support on Windows: pick a distribution and the plugin
                translates host paths and runs <code>magma</code> inside WSL,
                including reliable Stop.</li>
            <li>Run-configuration options for Magma's CLI flags &mdash; threads
                (<code>-t</code>), random seed (<code>-S</code>), startup file
                (<code>-s</code> / <code>-n</code>), <code>MAGMA_MEMORY_LIMIT</code>
                (accepts <code>2G</code>, <code>512M</code>, …), extra arguments.</li>
            <li>Global Magma settings under <i>Settings &rarr; Tools &rarr; Magma</i>.</li>
        </ul>
        <h3>1.0.0</h3>
        <ul>
            <li>Initial release.</li>
            <li>Syntax highlighting, brace matching, line/block comments.</li>
            <li>Live templates for the most common Magma constructs.</li>
            <li>Color settings page.</li>
        </ul>
    ]]></change-notes>

    <description><![CDATA[
        Language support for the <a href="https://magma.maths.usyd.edu.au/magma/">Magma</a>
        computer algebra system in IntelliJ-based IDEs.<br>
        <ul>
            <li>Syntax highlighting for <code>.m</code>, <code>.mag</code>, <code>.magma</code> and <code>.spec</code> files</li>
            <li>Brace matching and line/block comment support</li>
            <li>Live templates for common Magma constructs (function, procedure, intrinsic, …)</li>
            <li>Run configurations for Magma scripts, with native and WSL execution</li>
        </ul>
        <p><b>Disclaimer:</b> This is an unofficial, community-maintained plugin and is
        <b>not affiliated with, endorsed by, or developed by</b> the Magma Computational
        Algebra Group at the University of Sydney. <i>Magma</i> is a trademark of its
        respective owners.</p>
        Licensed under the Apache License 2.0.<br>
        Portions ported from the <a href="https://github.com/etairi/vscode-magma">vscode-magma</a>
        Visual Studio Code extension by Erkan Tairi (MIT-licensed).
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- File types -->
        <fileType
            name="Magma"
            implementationClass="com.renpe.intellij.magma.lang.MagmaFileType"
            fieldName="INSTANCE"
            language="Magma"
            extensions="m;mag;magma;magmarc;magmarc-dev"/>
        <fileType
            name="Magma Spec"
            implementationClass="com.renpe.intellij.magma.spec.SpecFileType"
            fieldName="INSTANCE"
            language="MagmaSpec"
            extensions="spec"/>

        <!-- Syntax highlighting -->
        <lang.syntaxHighlighterFactory
            language="Magma"
            implementationClass="com.renpe.intellij.magma.highlight.MagmaSyntaxHighlighterFactory"/>
        <lang.syntaxHighlighterFactory
            language="MagmaSpec"
            implementationClass="com.renpe.intellij.magma.spec.SpecSyntaxHighlighterFactory"/>
        <colorSettingsPage implementation="com.renpe.intellij.magma.highlight.MagmaColorSettingsPage"/>

        <!-- Commenter -->
        <lang.commenter language="Magma" implementationClass="com.renpe.intellij.magma.lang.MagmaCommenter"/>
        <lang.commenter language="MagmaSpec" implementationClass="com.renpe.intellij.magma.spec.SpecCommenter"/>

        <!-- Brace matching -->
        <lang.braceMatcher language="Magma" implementationClass="com.renpe.intellij.magma.brace.MagmaBraceMatcher"/>

        <!-- Live templates -->
        <defaultLiveTemplates file="liveTemplates/Magma.xml"/>
        <liveTemplateContext
            contextId="MAGMA_CODE"
            implementation="com.renpe.intellij.magma.template.MagmaTemplateContextType"/>

        <!-- Run configuration -->
        <configurationType implementation="com.renpe.intellij.magma.run.MagmaRunConfigurationType"/>
        <runConfigurationProducer implementation="com.renpe.intellij.magma.run.MagmaRunConfigurationProducer"/>
        <runLineMarkerContributor
            language="Magma"
            implementationClass="com.renpe.intellij.magma.run.MagmaRunLineMarkerContributor"/>

        <!-- Global settings -->
        <applicationService serviceImplementation="com.renpe.intellij.magma.settings.MagmaSettings"/>
        <applicationConfigurable
            parentId="tools"
            id="com.renpe.intellij.magma.settings.MagmaSettingsConfigurable"
            displayName="Magma"
            instance="com.renpe.intellij.magma.settings.MagmaSettingsConfigurable"/>
    </extensions>
</idea-plugin>
